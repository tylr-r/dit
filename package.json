{
  "name": "dit",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "pnpm@10.29.2",
  "scripts": {
    "dev": "turbo run dev --parallel",
    "build": "turbo run build",
    "build:ci": "pnpm run lint && pnpm run test:types && pnpm run security:history && pnpm run build",
    "lint": "turbo run lint",
    "preview": "turbo run preview",
    "deploy": "pnpm --filter @dit/web build && firebase deploy",
    "security:history": "node ./scripts/check-private-history.js",
    "test:unit": "turbo run test:unit",
    "test:unit:run": "turbo run test:unit:run",
    "test:types": "turbo run test:types",
    "test:e2e": "turbo run test:e2e"
  },
  "devDependencies": {
    "expo-module-scripts": "^5.0.8",
    "turbo": "^2.8.3"
  }
}
